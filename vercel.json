{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "name": "verifai-pro",
  "env": {
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "GEMINI_API_KEY": "@gemini_api_key"
  },
  "envDescription": {
    "ANTHROPIC_API_KEY": "Optional Anthropic API key for the proxy function",
    "GEMINI_API_KEY": "Gemini API key for the proxy function"
  },
  "public": false,
  "functions": {
    "api/**/*.js": {
      "memory": 3008,
      "maxDuration": 30
    }
  },
  "redirects": [],
  "rewrites": [],
  "headers": []
}
